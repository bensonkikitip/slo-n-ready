{
  "name": "budgetapp",
  "version": "4.4.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "xcrun simctl boot 7981E5F1-7920-42D3-BE73-44D68A65F28A 2>/dev/null; open -a Simulator && expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": {
            "strict": true
          }
        }
      ]
    },
    "moduleNameMapper": {
      "^expo-sqlite$": "<rootDir>/tests/__mocks__/expo-sqlite.ts",
      "^expo-crypto$": "<rootDir>/tests/__mocks__/expo-crypto.ts",
      "^expo-file-system/legacy$": "<rootDir>/tests/__mocks__/expo-file-system-legacy.ts"
    }
  },
  "dependencies": {
    "@expo-google-fonts/nunito": "^0.4.2",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.22",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "js-sha256": "^0.11.1",
    "papaparse": "^5.5.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^29.5.14",
    "@types/papaparse": "^5.5.2",
    "@types/react": "~19.1.0",
    "better-sqlite3": "^12.9.0",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "ts-jest": "^29.4.9",
    "typescript": "~5.9.2"
  },
  "private": true
}
