# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Financial data — NEVER commit real CSV exports or the local SQLite DB
local-data/
*.csv
*.db
# Local backup file (on-device data snapshot, not version-controlled)
slo-n-ready-backup.json

# App Store submission screenshots (build artifacts, not source)
Screenshots for AppStore/
# Exception: synthetic test fixtures are safe to commit (no real financial data)
!tests/fixtures/*.csv
!maestro/fixtures/*.csv
